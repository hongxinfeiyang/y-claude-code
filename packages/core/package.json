{
    "name": "@y-claude-code/core",
    "version": "0.1.0",
    "description": "核心引擎 — Agent 循环、工具系统、LLM 适配",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts --clean",
        "dev": "tsup src/index.ts --format esm --dts --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.39.0",
        "cosmiconfig": "^9.0.0",
        "fast-glob": "^3.3.2",
        "js-tiktoken": "^1.0.12",
        "openai": "^4.73.0",
        "pdf-parse": "^2.4.5"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "tsup": "^8.3.0",
        "typescript": "^5.6.0",
        "vitest": "^2.1.0"
    }
}
