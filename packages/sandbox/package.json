{
    "name": "@y-claude-code/sandbox",
    "version": "0.1.0",
    "description": "Docker 沙箱 — 容器隔离执行 Shell 命令",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts --clean",
        "dev": "tsup src/index.ts --format esm --dts --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "dockerode": "^4.0.2"
    },
    "devDependencies": {
        "@types/dockerode": "^3.3.31",
        "@types/node": "^25.9.1",
        "tsup": "^8.3.0",
        "typescript": "^5.6.0",
        "vitest": "^2.1.0"
    }
}
